#!/usr/bin/env bash
# gendoc setup — install / uninstall / upgrade
# Usage:
#   ./setup             # install (default)
#   ./setup install     # same as above
#   ./setup uninstall   # remove hook + delete runtime
#   ./setup upgrade     # git pull + re-deploy

set -e

REPO_URL="https://github.com/ibalasite/gendoc.git"
RUNTIME_DIR="$HOME/.claude/skills/gendoc"
SKILLS_SRC="$RUNTIME_DIR/skills"
CLAUDE_SKILLS_DIR="$HOME/.claude/skills"
SETTINGS_HOOK="$RUNTIME_DIR/bin/gendoc-settings-hook.py"
HOOK_CMD="bash \"$RUNTIME_DIR/bin/gendoc-session-update\""

CMD="${1:-install}"

log() { echo "$@"; }

# ── install ───────────────────────────────────────────────────────────────────
do_install() {
  command -v git    >/dev/null 2>&1 || { echo "❌ 需要 git"; exit 1; }
  command -v python3 >/dev/null 2>&1 || { echo "❌ 需要 python3"; exit 1; }

  if [[ -d "$RUNTIME_DIR/.git" ]]; then
    log "[install] $RUNTIME_DIR 已存在，執行 upgrade..."
    do_upgrade
    return
  fi

  log "[install] clone gendoc → $RUNTIME_DIR"
  git clone "$REPO_URL" "$RUNTIME_DIR"

  _deploy_skills
  _deploy_tools
  _register_hook

  log ""
  log "[install] 完成！重啟 Claude Code 讓技能生效。"
  log "  · 手動升級：$RUNTIME_DIR/setup upgrade"
  log "  · 解除安裝：$RUNTIME_DIR/setup uninstall"
}

# ── uninstall ─────────────────────────────────────────────────────────────────
do_uninstall() {
  log "[uninstall] 移除 hook..."
  if [[ -f "$SETTINGS_HOOK" ]]; then
    python3 "$SETTINGS_HOOK" remove
    python3 "$SETTINGS_HOOK" remove-guard
  fi

  log "[uninstall] 移除 copied skills..."
  if [[ -d "$SKILLS_SRC" ]]; then
    for skill_dir in "$SKILLS_SRC"/*/; do
      name="$(basename "$skill_dir")"
      [[ -d "$CLAUDE_SKILLS_DIR/$name" ]] && rm -rf "$CLAUDE_SKILLS_DIR/$name" && log "  · 刪除 ~/.claude/skills/$name"
    done
  fi

  log "[uninstall] 刪除 $RUNTIME_DIR..."
  rm -rf "$RUNTIME_DIR"

  log "[uninstall] 完成。"
}

# ── upgrade ───────────────────────────────────────────────────────────────────
do_upgrade() {
  if [[ ! -d "$RUNTIME_DIR/.git" ]]; then
    log "[upgrade] 找不到 $RUNTIME_DIR，請先執行 install。"
    exit 1
  fi

  log "[upgrade] git pull..."
  git -C "$RUNTIME_DIR" pull --ff-only

  _deploy_skills
  _deploy_tools

  log "[upgrade] 完成。"
}

# ── helpers ───────────────────────────────────────────────────────────────────
_deploy_skills() {
  log "[deploy] 複製 skills → ~/.claude/skills/"
  mkdir -p "$CLAUDE_SKILLS_DIR"
  for skill_dir in "$SKILLS_SRC"/*/; do
    name="$(basename "$skill_dir")"
    rm -rf "$CLAUDE_SKILLS_DIR/$name"
    cp -r "$skill_dir" "$CLAUDE_SKILLS_DIR/$name"
    log "  · $name"
  done
}

_deploy_tools() {
  log "[deploy] 複製 tools/bin → $RUNTIME_DIR/tools/bin/"
  # tools/bin already lives inside RUNTIME_DIR after clone; nothing extra to do.
  # If tools need building, add build steps here per-package.
  :
}

_register_hook() {
  log "[deploy] 註冊 SessionStart hook..."
  python3 "$SETTINGS_HOOK" add "$HOOK_CMD"
  log "[deploy] 註冊 guard hooks (PreToolUse / PostToolUse / Stop)..."
  python3 "$SETTINGS_HOOK" add-guard "$RUNTIME_DIR/tools/bin"
}

# ── dispatch ──────────────────────────────────────────────────────────────────
case "$CMD" in
  install)   do_install ;;
  uninstall) do_uninstall ;;
  upgrade)   do_upgrade ;;
  *)
    echo "用法：./setup [install|uninstall|upgrade]"
    echo "  install   — clone + deploy + register hook（預設）"
    echo "  uninstall — 移除 hook + 刪除 runtime"
    echo "  upgrade   — git pull + re-deploy"
    exit 1
    ;;
esac
