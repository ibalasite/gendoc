#!/usr/bin/env bash
# SessionStart hook: auto-upgrade gendoc (macOS / Linux / WSL / git-bash)
# Design: background, throttled (1h), lockfile, always exit 0

set +e

RUNTIME_DIR="$HOME/.claude/skills/gendoc"
STAMP_FILE="$RUNTIME_DIR/.last-update-check"
LOCK_DIR="$RUNTIME_DIR/.update-lock"
THROTTLE_SECONDS=3600

# Guard: runtime must exist
[[ -d "$RUNTIME_DIR/.git" ]] || exit 0

# Throttle
if [[ -f "$STAMP_FILE" ]]; then
  LAST=$(stat -c %Y "$STAMP_FILE" 2>/dev/null || stat -f %m "$STAMP_FILE" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  [[ $((NOW - LAST)) -lt $THROTTLE_SECONDS ]] && exit 0
fi

# Lock (atomic mkdir)
mkdir "$LOCK_DIR" 2>/dev/null || exit 0
trap 'rmdir "$LOCK_DIR" 2>/dev/null' EXIT

# Background upgrade
(
  touch "$STAMP_FILE"
  bash "$RUNTIME_DIR/setup" upgrade --quiet 2>/dev/null || true
) &

exit 0
