{
  "version": "4.0",
  "description": "gendoc 文件流水線定義 v4.0 — 完全 SSOT（Single Source of Truth）。metrics[] 定義 20 個量化指標，spec_rules[] 定義所有 Phase B step 的三層規格推導規則。dryrun_core.py 動態讀取此檔案，無硬編碼。新增節點只需在此加 step + metrics + spec_rules + 三件套 template，不需改任何 skill 代碼。",
  "condition_syntax": {
    "always": "永遠執行",
    "client_type != none": "有前台客戶端時執行（web/game）",
    "client_type == game": "遊戲類型時執行",
    "client_type != api-only": "非純 API 時執行",
    "has_admin_backend": "有 admin 後台時執行（state.has_admin_backend=true）"
  },
  "metrics": [
    {
      "id": "persona_count",
      "source_step": "IDEA",
      "grep_pattern": "^## Persona:",
      "fallback": 1,
      "description": "IDEA.md 中定義的用戶角色數量"
    },
    {
      "id": "moscow_p0_count",
      "source_step": "BRD",
      "grep_pattern": "^## P0|^\\| P0",
      "fallback": 3,
      "description": "BRD.md 中的 P0（最高優先級）需求數量"
    },
    {
      "id": "kpi_count",
      "source_step": "BRD",
      "grep_pattern": "^\\|.*:\\s*[0-9]+",
      "fallback": 1,
      "description": "BRD.md 中的 KPI 指標表列數量"
    },
    {
      "id": "user_story_count",
      "source_step": "PRD",
      "grep_pattern": "^(##|###) US-",
      "fallback": 1,
      "description": "PRD.md 中的用戶故事數量"
    },
    {
      "id": "feature_count",
      "source_step": "PRD",
      "grep_pattern": "^(##|###) FE-",
      "fallback": 1,
      "description": "PRD.md 中的功能數量"
    },
    {
      "id": "use_case_count",
      "source_step": "PRD",
      "grep_pattern": "^(##|###) UC-",
      "fallback": 1,
      "description": "PRD.md 中的用例數量"
    },
    {
      "id": "total_ac_count",
      "source_step": "PRD",
      "grep_pattern": "- \\[ \\]",
      "fallback": 5,
      "description": "PRD.md 中的驗收標準（待完成項）數量"
    },
    {
      "id": "constant_count",
      "source_step": "CONSTANTS",
      "grep_pattern": "^\\| [A-Z_]",
      "fallback": 3,
      "description": "CONSTANTS.md 中的常量定義表列數量"
    },
    {
      "id": "screen_count",
      "source_step": "PDD",
      "grep_pattern": "^### Screen",
      "fallback": 1,
      "description": "PDD.md 中定義的畫面數量"
    },
    {
      "id": "flow_count",
      "source_step": "PDD",
      "grep_pattern": "^### (User Flow|Flow)",
      "fallback": 1,
      "description": "PDD.md 中的用戶流程數量"
    },
    {
      "id": "total_component_count",
      "source_step": "PDD",
      "grep_pattern": "^- (Button|Input|Card|Modal|Header|Footer)",
      "fallback": 3,
      "description": "PDD.md 中的 UI 元件清單數量"
    },
    {
      "id": "design_token_count",
      "source_step": "VDD",
      "grep_pattern": "^- `",
      "fallback": 5,
      "description": "VDD.md 中定義的設計令牌數量"
    },
    {
      "id": "color_count",
      "source_step": "VDD",
      "grep_pattern": "^\\| #[0-9A-Fa-f]",
      "fallback": 5,
      "description": "VDD.md 中的色彩調色板條目數量"
    },
    {
      "id": "entity_count",
      "source_step": "EDD",
      "grep_pattern": "^\\s*class ",
      "fallback": 3,
      "description": "EDD.md 中定義的資料實體數量"
    },
    {
      "id": "relationship_count",
      "source_step": "EDD",
      "grep_pattern": "(--|<\\|--|o--|o\\|)",
      "fallback": 3,
      "description": "EDD.md 中的實體關聯數量"
    },
    {
      "id": "rest_endpoint_count",
      "source_step": "EDD",
      "grep_pattern": "(<<REST>>|<<Interface>>|GET|POST|PUT|DELETE)",
      "fallback": 5,
      "description": "EDD.md 中的 REST API 端點數量"
    },
    {
      "id": "domain_count",
      "source_step": "EDD",
      "grep_pattern": "^### ",
      "fallback": 2,
      "description": "EDD.md 中的領域分類數量"
    },
    {
      "id": "layer_count",
      "source_step": "ARCH",
      "grep_pattern": "^\\| [A-Za-z0-9_]",
      "fallback": 4,
      "description": "ARCH.md 中的技術棧層級數量"
    },
    {
      "id": "service_count",
      "source_step": "ARCH",
      "grep_pattern": "^#### ",
      "fallback": 3,
      "description": "ARCH.md 中的微服務/模組數量"
    },
    {
      "id": "nfr_count",
      "source_step": "ARCH",
      "grep_pattern": "^- \\[",
      "fallback": 12,
      "description": "ARCH.md 中的非功能性需求（NFR）數量"
    }
  ],
  "steps": [
    {
      "id": "IDEA",
      "type": "IDEA",
      "layer": "需求層",
      "output": [
        "docs/IDEA.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-auto",
      "commit_prefix": "docs(gendoc)[IDEA]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（需求層根文件）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "BRD",
      "type": "BRD",
      "layer": "需求層",
      "output": [
        "docs/BRD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-auto",
      "commit_prefix": "docs(gendoc)[BRD]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（商業需求）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "PRD",
      "type": "PRD",
      "layer": "需求層",
      "output": [
        "docs/PRD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[PRD]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（產品需求）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "CONSTANTS",
      "type": "CONSTANTS",
      "layer": "需求層",
      "output": [
        "docs/CONSTANTS.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[CONSTANTS]",
      "note": "從 PRD 提取所有關鍵業務數值（倍率、閾值、SLO、RTP、rate-limit 等）到 docs/CONSTANTS.md（並同步輸出 docs/constants.json）。下游所有文件（EDD/BDD/test-plan/runbook）生成時必須讀取此文件並引用，確保跨文件數值一致性。這是 AI 可實作性的核心機制。",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（常量定義）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "PDD",
      "type": "PDD",
      "layer": "需求層",
      "output": [
        "docs/PDD.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[PDD]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（產品設計）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "VDD",
      "type": "VDD",
      "layer": "設計層",
      "output": [
        "docs/VDD.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[VDD]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（視覺設計）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "EDD",
      "type": "EDD",
      "layer": "設計層",
      "output": [
        "docs/EDD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[EDD]",
      "note": "EDD 生成採用三 subagent 多 pass 架構（見 EDD.gen.md）：Pass-A 生成 §1-§8，Pass-B 生成 §4.5 UML，Pass-C 生成 §9-§21。三個 pass 均輸出到同一個 docs/EDD.md，review loop 在全部完成後執行。",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（實體設計）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "ARCH",
      "type": "ARCH",
      "layer": "設計層",
      "output": [
        "docs/ARCH.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ARCH]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A 文件（架構設計）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "DRYRUN",
      "type": "DRYRUN",
      "layer": "設計層-規劃",
      "output": [
        "docs/MANIFEST.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "special_skill": "gendoc-gen-dryrun",
      "commit_prefix": "docs(gendoc)[DRYRUN]",
      "note": "讀取 EDD/PRD/ARCH 計算量化基線，生成 docs/MANIFEST.md + .gendoc-rules/*.json。不跑 review→fix loop（special_skill 處理）。",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase A→B 相位邊界（生成量化基線）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "API",
      "type": "API",
      "layer": "設計層",
      "output": [
        "docs/API.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[API]",
      "spec_rules": {
        "quantitative_specs": {
          "min_endpoint_count": "max(5, rest_endpoint_count)"
        },
        "content_mapping": {
          "entity_coverage": "All {entity_count} EDD entities must be referenced in API request/response models"
        },
        "cross_file_validation": {
          "entity_parity": "API.md endpoints >= EDD entity count ({entity_count})"
        }
      }
    },
    {
      "id": "SCHEMA",
      "type": "SCHEMA",
      "layer": "設計層",
      "output": [
        "docs/SCHEMA.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[SCHEMA]",
      "spec_rules": {
        "quantitative_specs": {
          "min_table_count": "max(3, entity_count)"
        },
        "content_mapping": {
          "entity_coverage": "All {entity_count} EDD entities must have corresponding database tables"
        },
        "cross_file_validation": {
          "entity_parity": "SCHEMA tables == EDD entities ({entity_count})"
        }
      }
    },
    {
      "id": "FRONTEND",
      "type": "FRONTEND",
      "layer": "設計層",
      "output": [
        "docs/FRONTEND.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[FRONTEND]",
      "spec_rules": {
        "quantitative_specs": {
          "min_component_count": "max(3, total_component_count)"
        },
        "content_mapping": {
          "screen_coverage": "Components for all {screen_count} screens from PDD"
        },
        "cross_file_validation": {
          "pdd_alignment": "FRONTEND components >= PDD components ({total_component_count})"
        }
      }
    },
    {
      "id": "AUDIO",
      "type": "AUDIO",
      "layer": "設計層",
      "output": [
        "docs/AUDIO.md"
      ],
      "multi_file": false,
      "condition": "client_type == game",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[AUDIO]",
      "note": "音效設計文件：BGM/SFX/VO 清單、音效觸發邏輯、引擎設定（Cocos/Unity/HTML5 Web Audio）、資產規格、效能預算",
      "spec_rules": {
        "quantitative_specs": {
          "min_bgm_entries": 1,
          "min_sfx_entries": 1
        },
        "content_mapping": {
          "audio_triggers": "Sound event mapping for game scenarios"
        },
        "cross_file_validation": {}
      }
    },
    {
      "id": "ANIM",
      "type": "ANIM",
      "layer": "設計層",
      "output": [
        "docs/ANIM.md"
      ],
      "multi_file": false,
      "condition": "client_type == game",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ANIM]",
      "note": "動畫特效設計文件：骨骼動畫/幀動畫/Tween/粒子/Shader、引擎設定（Cocos/Unity/HTML5 PixiJS）、效能預算與 LOD 策略",
      "spec_rules": {
        "quantitative_specs": {
          "min_animation_defs": 3
        },
        "content_mapping": {
          "animation_coverage": "All character/UI animations defined"
        },
        "cross_file_validation": {}
      }
    },
    {
      "id": "CLIENT_IMPL",
      "type": "CLIENT_IMPL",
      "layer": "設計層",
      "output": [
        "docs/CLIENT_IMPL.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[CLIENT_IMPL]",
      "note": "客戶端實作規格書：依 EDD §3.3 偵測引擎（Cocos Creator / Unity WebGL / React / Vue / HTML5），自動展開對應的場景結構、資源載入策略、動畫觸發規格、AudioManager 架構、VFX 整合規格。上游：EDD + VDD + ANIM + AUDIO。",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {
          "scene_structure": "All PDD screens have implementation details"
        },
        "cross_file_validation": {}
      }
    },
    {
      "id": "ADMIN_IMPL",
      "type": "ADMIN_IMPL",
      "layer": "設計層",
      "output": [
        "docs/ADMIN_IMPL.md"
      ],
      "multi_file": false,
      "condition": "has_admin_backend",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ADMIN_IMPL]",
      "note": "Admin 後台實作規格（預設技術棧：Vue3 + Element Plus + Vite）。包含：RBAC 架構、Component 規範、路由設計、API 串接、Pinia Store、部署配置。上游：EDD（§3.3 _ADMIN_FRAMEWORK, §5.5 RBAC 模型）+ ARCH + API + SCHEMA。觸發條件：has_admin_backend=true（在 gendoc-auto Session Config 中設定）。",
      "spec_rules": {
        "quantitative_specs": {
          "min_rbac_roles": 2
        },
        "content_mapping": {
          "role_coverage": "All user roles from ARCH defined"
        },
        "cross_file_validation": {}
      }
    },
    {
      "id": "RESOURCE",
      "type": "RESOURCE",
      "layer": "設計層",
      "output": [
        "docs/RESOURCE.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[RESOURCE]",
      "note": "AI 資產生產訂單：從 VDD.md（必讀）、ANIM.md（若存在）、AUDIO.md（若存在）推導出需要哪些具體資產檔案，生成包含 ID/檔名/type/source_tool/prompt/dimensions/file_size_budget/status/output_path/description 的結構化清單。設計師確認 prompt 後即可送入 AI 工具（Midjourney/Suno/ElevenLabs 等）執行生產。觸發條件：client_type != none（有前端/客戶端的專案）。",
      "spec_rules": {
        "quantitative_specs": {
          "min_resource_entries": "max(5, constant_count)"
        },
        "content_mapping": {
          "asset_inventory": "List all resources with IDs, types, prompts"
        },
        "cross_file_validation": {
          "constant_mapping": "Resources >= constants"
        }
      }
    },
    {
      "id": "UML",
      "type": "UML",
      "layer": "設計層",
      "output": [
        "docs/diagrams/"
      ],
      "output_glob": "docs/diagrams/*.md",
      "multi_file": true,
      "condition": "always",
      "special_skill": "gendoc-gen-diagrams",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[UML]",
      "note": "特殊步驟：呼叫 gendoc-gen-diagrams skill，生成 9 大 UML 圖 + class-inventory.md。排在所有設計文件（API/SCHEMA/FRONTEND/AUDIO/ANIM/CLIENT_IMPL/ADMIN_IMPL/RESOURCE）之後，確保所有上游文件已存在。class-inventory.md 供 test-plan 和 RTM 讀取。has_admin_backend=true 時額外生成 3 張 Admin 圖（RBAC Entity Diagram / Admin Login Sequence / Admin-Server C4 Container）。",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase B 文件（UML 圖表）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "test-plan",
      "type": "test-plan",
      "layer": "品質層",
      "output": [
        "docs/test-plan.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[test-plan]",
      "spec_rules": {
        "quantitative_specs": {
          "min_h2_sections": "layer_count + 4"
        },
        "content_mapping": {
          "layer_coverage": "Test strategy for all {layer_count} architecture layers"
        },
        "cross_file_validation": {
          "architecture_alignment": "test-plan sections >= ARCH layers + 4"
        }
      }
    },
    {
      "id": "BDD-server",
      "type": "BDD-server",
      "layer": "品質層",
      "output": [
        "features/"
      ],
      "output_glob": "features/*.feature",
      "multi_file": true,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "test(gendoc)[BDD-server]",
      "note": "BDD-server.gen.md 指示生成多個 .feature 檔案 + step definitions skeleton；BDD-server.review.md 審查所有 features/*.feature（含上游 PRD/CONSTANTS 數值對照）",
      "spec_rules": {
        "quantitative_specs": {
          "min_scenario_count": "ceil(user_story_count * 0.8)"
        },
        "content_mapping": {
          "user_story_coverage": "All {user_story_count} user stories have corresponding BDD scenarios"
        },
        "cross_file_validation": {
          "scenario_coverage": "BDD scenarios >= 80% of user stories"
        }
      }
    },
    {
      "id": "BDD-client",
      "type": "BDD-client",
      "layer": "品質層",
      "output": [
        "features/client/"
      ],
      "output_glob": "features/client/*.feature",
      "multi_file": true,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "test(gendoc)[BDD-client]",
      "note": "BDD-client.gen.md 指示生成多個 .feature 檔案 + step definitions skeleton；BDD-client.review.md 審查所有 features/client/*.feature（含上游 PRD/CONSTANTS 數值對照）。has_admin_backend=true 時含 Admin RBAC BDD scenarios（login/permission/audit）。",
      "spec_rules": {
        "quantitative_specs": {
          "min_scenario_count": "ceil(user_story_count * 0.6)"
        },
        "content_mapping": {
          "ui_scenario_coverage": "Client UI scenarios for key flows"
        },
        "cross_file_validation": {
          "scenario_coverage": "Client BDD >= 60% of user stories"
        }
      }
    },
    {
      "id": "RTM",
      "type": "RTM",
      "layer": "品質層",
      "output": [
        "docs/RTM.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[RTM]",
      "spec_rules": {
        "quantitative_specs": {
          "min_row_count": "max(1, user_story_count)"
        },
        "content_mapping": {
          "requirement_traceability": "All {user_story_count} user stories traced to test cases"
        },
        "cross_file_validation": {
          "coverage": "RTM rows >= user_story_count"
        }
      }
    },
    {
      "id": "runbook",
      "type": "runbook",
      "layer": "運維層",
      "output": [
        "docs/runbook.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[runbook]",
      "spec_rules": {
        "quantitative_specs": {},
        "content_mapping": {"note": "Phase B 文件（運維手冊）"},
        "cross_file_validation": {}
      }
    },
    {
      "id": "LOCAL_DEPLOY",
      "type": "LOCAL_DEPLOY",
