{
  "version": "4.0",
  "description": "gendoc 文件流水線定義 v4.1 — Pipeline-first SSOT。各 step 的 input 字段定義所需的上游文件清單。review.sh 和 dryrun_core.py 動態讀取此檔案。",
  "steps": [
    {
      "id": "IDEA",
      "type": "IDEA",
      "layer": "需求層",
      "output": [
        "docs/IDEA.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-auto",
      "commit_prefix": "docs(gendoc)[IDEA]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 2
      },
      "input": []
    },
    {
      "id": "BRD",
      "type": "BRD",
      "layer": "需求層",
      "output": [
        "docs/BRD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-auto",
      "commit_prefix": "docs(gendoc)[BRD]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 3
      },
      "input": [
        "docs/IDEA.md"
      ]
    },
    {
      "id": "PRD",
      "type": "PRD",
      "layer": "需求層",
      "output": [
        "docs/PRD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[PRD]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 5
      },
      "input": [
        "docs/IDEA.md",
        "docs/BRD.md"
      ]
    },
    {
      "id": "CONSTANTS",
      "type": "CONSTANTS",
      "layer": "需求層",
      "output": [
        "docs/CONSTANTS.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[CONSTANTS]",
      "note": "從 PRD 提取業務數值（倍率、閾值、SLO、rate-limit）為數值 SSOT，下游所有文件參照確保一致性。",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 2
      },
      "input": [
        "docs/PRD.md"
      ]
    },
    {
      "id": "PDD",
      "type": "PDD",
      "layer": "需求層",
      "output": [
        "docs/PDD.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[PDD]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 3
      },
      "input": [
        "docs/PRD.md"
      ]
    },
    {
      "id": "VDD",
      "type": "VDD",
      "layer": "需求層",
      "output": [
        "docs/VDD.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[VDD]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 3
      },
      "input": [
        "docs/PRD.md"
      ]
    },
    {
      "id": "EDD",
      "type": "EDD",
      "layer": "設計層",
      "output": [
        "docs/EDD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[EDD]",
      "note": "三 pass 架構（Pass-A §1-§8 / Pass-B §4.5 UML / Pass-C §9-§21），三 pass 完成後才執行 review loop。",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 4
      },
      "input": [
        "docs/PRD.md",
        "docs/CONSTANTS.md"
      ]
    },
    {
      "id": "ARCH",
      "type": "ARCH",
      "layer": "設計層",
      "output": [
        "docs/ARCH.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ARCH]",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_h2_sections": 4
      },
      "input": [
        "docs/EDD.md"
      ]
    },
    {
      "id": "DRYRUN",
      "type": "DRYRUN",
      "layer": "設計層-規劃",
      "output": [
        "docs/MANIFEST.md",
        ".gendoc-rules/"
      ],
      "output_glob": "docs/MANIFEST.md|.gendoc-rules/*.json",
      "multi_file": true,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[DRYRUN]",
      "note": "DRYRUN 相位邊界：根據 pipeline.json 動態讀取所有 DRYRUN 前的文件，計算量化指標，推導 DRYRUN 后的 step 規格。生成 docs/MANIFEST.md + .gendoc-rules/*.json。【重要】.gendoc-rules/*.json 是後續所有 gate-check 的量化門檻依據，必須完整生成並在 pipeline output 中宣告。不跑 review→fix loop（special_skill 直接處理）。",
      "spec_rules": {
        "max_placeholder_count": 0,
        "min_rules_json_count": 1
      },
      "input": [
        "docs/IDEA.md",
        "docs/BRD.md",
        "docs/PRD.md",
        "docs/CONSTANTS.md",
        "docs/PDD.md",
        "docs/VDD.md",
        "docs/EDD.md",
        "docs/ARCH.md"
      ]
    },
    {
      "id": "API",
      "type": "API",
      "layer": "設計層",
      "output": [
        "docs/API.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[API]",
      "note": "從 PRD（user story 範圍）+ EDD（entity 模型）+ CONSTANTS（rate-limit/SLO）推導 endpoint 規格。",
      "spec_rules": {
        "min_endpoint_count": "max(5, {rest_endpoint_count})",
        "min_fields_per_endpoint": 2,
        "min_h2_sections": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PRD.md",
        "docs/EDD.md",
        "docs/CONSTANTS.md"
      ]
    },
    {
      "id": "SCHEMA",
      "type": "SCHEMA",
      "layer": "設計層",
      "output": [
        "docs/SCHEMA.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[SCHEMA]",
      "note": "從 EDD（entity 模型）+ CONSTANTS（capacity 限制）+ PDD（client-specific entities）推導資料庫 schema。",
      "spec_rules": {
        "min_table_count": "max(3, {entity_count})",
        "min_columns_per_table": "max(3, {avg_entity_field_count})",
        "min_h2_sections": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/CONSTANTS.md",
        "docs/PDD.md"
      ]
    },
    {
      "id": "FRONTEND",
      "type": "FRONTEND",
      "layer": "設計層",
      "output": [
        "docs/FRONTEND.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[FRONTEND]",
      "spec_rules": {
        "min_component_count": "max(3, {entity_count})",
        "min_h2_sections": 3,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PDD.md",
        "docs/VDD.md",
        "docs/CONSTANTS.md"
      ]
    },
    {
      "id": "AUDIO",
      "type": "AUDIO",
      "layer": "設計層",
      "output": [
        "docs/AUDIO.md"
      ],
      "multi_file": false,
      "condition": "client_type == game",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[AUDIO]",
      "note": "音效設計文件：BGM/SFX/VO 清單、音效觸發邏輯、引擎設定（Cocos/Unity/HTML5 Web Audio）、資產規格、效能預算",
      "spec_rules": {
        "min_bgm_entries": 1,
        "min_sfx_entries": 1,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md"
      ]
    },
    {
      "id": "ANIM",
      "type": "ANIM",
      "layer": "設計層",
      "output": [
        "docs/ANIM.md"
      ],
      "multi_file": false,
      "condition": "client_type == game",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ANIM]",
      "note": "動畫特效設計文件：骨骼動畫/幀動畫/Tween/粒子/Shader、引擎設定（Cocos/Unity/HTML5 PixiJS）、效能預算與 LOD 策略",
      "spec_rules": {
        "min_animation_defs": 3,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md"
      ]
    },
    {
      "id": "CLIENT_IMPL",
      "type": "CLIENT_IMPL",
      "layer": "設計層",
      "output": [
        "docs/CLIENT_IMPL.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[CLIENT_IMPL]",
      "note": "依 EDD §3.3 偵測引擎（Cocos / Unity WebGL / React / Vue / HTML5），展開場景結構、資源載入、動畫觸發、AudioManager、VFX 整合規格。",
      "spec_rules": {
        "min_h2_sections": 4,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/FRONTEND.md",
        "docs/VDD.md",
        "docs/ANIM.md",
        "docs/AUDIO.md"
      ]
    },
    {
      "id": "ADMIN_IMPL",
      "type": "ADMIN_IMPL",
      "layer": "設計層",
      "output": [
        "docs/ADMIN_IMPL.md"
      ],
      "multi_file": false,
      "condition": "has_admin_backend",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ADMIN_IMPL]",
      "note": "Admin 後台實作規格（預設 Vue3 + Element Plus + Vite）：RBAC 架構、路由設計、API 串接、Pinia Store、部署配置。觸發條件：has_admin_backend=true。",
      "spec_rules": {
        "min_rbac_roles": 2,
        "min_h2_sections": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/API.md"
      ]
    },
    {
      "id": "RESOURCE",
      "type": "RESOURCE",
      "layer": "設計層",
      "output": [
        "docs/RESOURCE.md"
      ],
      "multi_file": false,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[RESOURCE]",
      "note": "AI 資產生產訂單：從 VDD/ANIM/AUDIO 推導資產清單，每筆含 ID/檔名/type/source_tool/prompt/dimensions/file_size_budget/status/output_path，可直接送入 AI 工具。",
      "spec_rules": {
        "min_resource_entries": "max(5, {component_count})",
        "min_h2_sections": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/VDD.md",
        "docs/ANIM.md",
        "docs/AUDIO.md"
      ]
    },
    {
      "id": "UML",
      "type": "UML",
      "layer": "設計層",
      "output": [
        "docs/diagrams/"
      ],
      "output_glob": "docs/diagrams/*.md",
      "multi_file": true,
      "condition": "always",
      "special_skill": "gendoc-gen-diagrams",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[UML]",
      "note": "特殊步驟：gendoc-gen-diagrams 生成 9 張 UML 圖 + class-inventory.md（後者供 test-plan/RTM 讀取）。排在所有設計文件之後以確保上游就緒。has_admin_backend=true 時額外輸出 3 張 Admin 圖。",
      "spec_rules": {
        "min_diagram_count": 3,
        "min_class_count": "max(3, {entity_count})",
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md"
      ]
    },
    {
      "id": "test-plan",
      "type": "test-plan",
      "layer": "品質層",
      "output": [
        "docs/test-plan.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[test-plan]",
      "spec_rules": {
        "min_h2_sections": "arch_layer_count + 4",
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PRD.md",
        "docs/EDD.md",
        "docs/SCHEMA.md"
      ]
    },
    {
      "id": "BDD-server",
      "type": "BDD-server",
      "layer": "品質層",
      "output": [
        "features/"
      ],
      "output_glob": "features/*.feature",
      "multi_file": true,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "test(gendoc)[BDD-server]",
      "note": "BDD-server.gen.md 指示生成多個 .feature 檔案 + step definitions skeleton；BDD-server.review.md 審查所有 features/*.feature（含上游 PRD/CONSTANTS 數值對照）",
      "spec_rules": {
        "min_scenario_count": "ceil(user_story_count * 0.8)",
        "min_steps_per_scenario": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PRD.md",
        "docs/EDD.md",
        "docs/API.md"
      ]
    },
    {
      "id": "BDD-client",
      "type": "BDD-client",
      "layer": "品質層",
      "output": [
        "features/client/"
      ],
      "output_glob": "features/client/*.feature",
      "multi_file": true,
      "condition": "client_type != none",
      "handled_by": "gendoc-flow",
      "commit_prefix": "test(gendoc)[BDD-client]",
      "note": "BDD-client.gen.md 指示生成多個 .feature 檔案 + step definitions skeleton；BDD-client.review.md 審查所有 features/client/*.feature（含上游 PRD/CONSTANTS 數值對照）。has_admin_backend=true 時含 Admin RBAC BDD scenarios（login/permission/audit）。",
      "spec_rules": {
        "min_scenario_count": "ceil(user_story_count * 0.6)",
        "min_steps_per_scenario": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PRD.md",
        "docs/PDD.md",
        "docs/FRONTEND.md"
      ]
    },
    {
      "id": "RTM",
      "type": "RTM",
      "layer": "品質層",
      "output": [
        "docs/RTM.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[RTM]",
      "spec_rules": {
        "min_row_count": "max(1, {user_story_count})",
        "min_columns_per_row": 4,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/PRD.md",
        "docs/EDD.md",
        "docs/test-plan.md"
      ]
    },
    {
      "id": "runbook",
      "type": "runbook",
      "layer": "運維層",
      "output": [
        "docs/runbook.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[runbook]",
      "spec_rules": {
        "min_h2_sections": 4,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md",
        "docs/API.md",
        "docs/SCHEMA.md"
      ]
    },
    {
      "id": "LOCAL_DEPLOY",
      "type": "LOCAL_DEPLOY",
      "layer": "運維層",
      "output": [
        "docs/LOCAL_DEPLOY.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[LOCAL_DEPLOY]",
      "note": "LOCAL_DEPLOY.gen.md 要求生成後自動執行 docker/sandbox 驗證，確認所有命令可成功執行",
      "spec_rules": {
        "min_h2_sections": 3,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md",
        "docs/SCHEMA.md"
      ]
    },
    {
      "id": "CICD",
      "type": "CICD",
      "layer": "運維層",
      "output": [
        "docs/CICD.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[CICD]",
      "note": "CI/CD Pipeline 設計文件。排在 LOCAL_DEPLOY 之後以讀取 §6 Make targets / Secret Bootstrap。§4 Make targets 必須與 LOCAL_DEPLOY §6 完全一致（quality-bar 強制）。",
      "spec_rules": {
        "min_h2_sections": 3,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/ARCH.md",
        "docs/LOCAL_DEPLOY.md"
      ]
    },
    {
      "id": "DEVELOPER_GUIDE",
      "type": "DEVELOPER_GUIDE",
      "layer": "運維層",
      "output": [
        "docs/DEVELOPER_GUIDE.md"
      ],
      "multi_file": false,
      "condition": "always",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[DEVELOPER_GUIDE]",
      "note": "開發者日常操作指南。排在 CICD 之後讀取 §4 Shared Make targets 與 §8 Gitea。",
      "spec_rules": {
        "min_h2_sections": 4,
        "min_lines_per_section": 3,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/EDD.md",
        "docs/LOCAL_DEPLOY.md",
        "docs/CICD.md",
        "docs/runbook.md"
      ]
    },
    {
      "id": "UML-CICD",
      "type": "UML-CICD",
      "layer": "運維層",
      "output": [
        "docs/diagrams/"
      ],
      "output_glob": "docs/diagrams/cicd-*.md",
      "multi_file": true,
      "condition": "always",
      "special_skill": "gendoc-gen-diagrams",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[UML-CICD]",
      "note": "CI/CD UML 圖表。排在 CICD 之後。Secret Bootstrap + Make targets 視覺化需讀 LOCAL_DEPLOY.md。",
      "spec_rules": {
        "min_diagram_count": 2,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/CICD.md",
        "docs/EDD.md",
        "docs/LOCAL_DEPLOY.md"
      ]
    },
    {
      "id": "ALIGN",
      "type": "ALIGN",
      "layer": "稽核層",
      "output": [
        "docs/ALIGN_REPORT.md"
      ],
      "multi_file": false,
      "condition": "always",
      "special_skill": "gendoc-align-check",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ALIGN]",
      "note": "全局跨層對齊檢查：驗證完整依賴鏈 IDEA→BRD→PRD→...→RTM→Code 的所有文件對齊、文件↔程式碼、程式碼↔測試的一致性。包括運維層（CICD/LOCAL_DEPLOY/DEVELOPER_GUIDE）的跨層對齊。",
      "spec_rules": {
        "min_h2_sections": 2,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/IDEA.md",
        "docs/BRD.md",
        "docs/PRD.md",
        "docs/PDD.md",
        "docs/VDD.md",
        "docs/EDD.md",
        "docs/ARCH.md",
        "docs/API.md",
        "docs/SCHEMA.md",
        "docs/FRONTEND.md",
        "docs/AUDIO.md",
        "docs/ANIM.md",
        "docs/CLIENT_IMPL.md",
        "docs/ADMIN_IMPL.md",
        "docs/test-plan.md",
        "docs/CICD.md",
        "docs/LOCAL_DEPLOY.md",
        "docs/DEVELOPER_GUIDE.md",
        "docs/runbook.md"
      ]
    },
    {
      "id": "ALIGN-FIX",
      "type": "ALIGN-FIX",
      "layer": "稽核層",
      "output": [
        "docs/ALIGN_REPORT.md"
      ],
      "multi_file": false,
      "condition": "always",
      "special_skill": "gendoc-align-fix",
      "handled_by": "gendoc-flow",
      "commit_prefix": "docs(gendoc)[ALIGN-FIX]",
      "note": "依 ALIGN_REPORT.md 自動修復對齊問題（all layers），每條 fix verify 後 commit。",
      "spec_rules": {
        "min_h2_sections": 2,
        "max_placeholder_count": 0
      },
      "input": [
        "docs/IDEA.md",
        "docs/BRD.md",
        "docs/PRD.md",
        "docs/PDD.md",
        "docs/VDD.md",
        "docs/EDD.md",
        "docs/ARCH.md",
        "docs/API.md",
        "docs/SCHEMA.md",
        "docs/FRONTEND.md",
        "docs/AUDIO.md",
        "docs/ANIM.md",
